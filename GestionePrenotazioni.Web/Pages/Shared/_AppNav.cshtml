@model IndexModel
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
}

<aside class="app-menu" aria-label="Menu principale" data-compact-workflow="@Model.IsCompactWorkflowPage.ToString().ToLowerInvariant()">
    <div class="menu-head">
        <button class="brand-mark" type="button" data-menu-toggle aria-label="Comprimi menu" title="Comprimi menu">
            <span class="brand-badge">GP</span>
            <strong class="nav-label">Prenotazioni</strong>
            <svg class="brand-menu-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
        </button>
        <div class="collapsed-context" aria-label="Turno selezionato">
            <strong>@(Model.SelectedDate?.Date.ToString("dd/MM") ?? "--/--")</strong>
            <span>@(Model.SelectedShift?.StartsAt?.ToString("HH:mm") ?? "--:--") · @(Model.SelectedShift?.Name ?? "turno non selezionato")</span>
        </div>
    </div>
    <nav>
        <a class="nav-link @(currentPage == "/Index" ? "active" : string.Empty)" asp-page="/Index" asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId" asp-route-SelectedEventId="@Model.SelectedEventId" asp-route-SelectedDateId="@Model.SelectedDateId" asp-route-SelectedShiftId="@Model.SelectedShiftId">
            <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 12 12 5l8 7v7a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1z" /></svg></span>
            <span class="nav-label">Panoramica</span>
        </a>
        @if (Model.CanManageReservations)
        {
            <a class="nav-link @(currentPage == "/Bookings" ? "active" : string.Empty)" asp-page="/Bookings" asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId" asp-route-SelectedEventId="@Model.SelectedEventId" asp-route-SelectedDateId="@Model.SelectedDateId" asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 3h10v4H7zM5 7h14v14H5zM8 12h8M8 16h6" /></svg></span>
                <span class="nav-label">Prenotazioni</span>
            </a>
        }
        @if (Model.CanReception)
        {
            <a class="nav-link @(currentPage == "/Reception" ? "active" : string.Empty)" asp-page="/Reception" asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId" asp-route-SelectedEventId="@Model.SelectedEventId" asp-route-SelectedDateId="@Model.SelectedDateId" asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M8 21v-2a4 4 0 0 1 8 0v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM4 16h4M16 16h4" /></svg></span>
                <span class="nav-label">Accoglienza</span>
            </a>
        }
        @if (Model.CanManageReservations)
        {
            <a class="nav-link @(currentPage == "/Assignments" ? "active" : string.Empty)" asp-page="/Assignments" asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId" asp-route-SelectedEventId="@Model.SelectedEventId" asp-route-SelectedDateId="@Model.SelectedDateId" asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 10h16M6 10v9M18 10v9M8 6h8a3 3 0 0 1 3 3v1H5V9a3 3 0 0 1 3-3z" /></svg></span>
                <span class="nav-label">Assegnazione</span>
            </a>
        }
        @if (Model.CanManageReservations || Model.CanReception)
        {
            <a class="nav-link @(currentPage == "/Exports" ? "active" : string.Empty)" asp-page="/Exports" asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId" asp-route-SelectedEventId="@Model.SelectedEventId" asp-route-SelectedDateId="@Model.SelectedDateId" asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3v12m0 0 4-4m-4 4-4-4M5 19h14" /></svg></span>
                <span class="nav-label">Export</span>
            </a>
        }
        @if (Model.CanManageSetup)
        {
            <p class="nav-section">Configurazione</p>
            <a class="nav-link @(currentPage == "/Config" ? "active" : string.Empty)" asp-page="/Config" asp-route-ConfigSection="@Model.ActiveConfigSection" asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId" asp-route-SelectedEventId="@Model.SelectedEventId" asp-route-SelectedDateId="@Model.SelectedDateId" asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM4 12h2m12 0h2M12 4v2m0 12v2M6.3 6.3l1.4 1.4m8.6 8.6 1.4 1.4m0-11.4-1.4 1.4m-8.6 8.6-1.4 1.4" /></svg></span>
                <span class="nav-label">Menu configurazione</span>
            </a>
        }
    </nav>
    <section class="menu-context" aria-label="Contesto operativo">
        <p class="nav-section">Contesto</p>
        <div class="context-card">
            <strong>@(Model.SelectedEvent?.Name ?? "Gestione prenotazioni")</strong>
            <span>@Model.OrganizationName</span>
            <span>@Model.SelectedDate?.Date.ToString("dd/MM/yyyy") · Turno @(Model.SelectedShift?.Name ?? "non selezionato")</span>
        </div>
        <form method="get" class="menu-context-form" data-context-form data-confirm-context-change="@(Model.IsReceptionPage ? "true" : "false")">
            <input type="hidden" asp-for="ConfigSection" />
            <label>Organizzazione <select asp-for="SelectedOrganizationId" asp-items="Model.OrganizationOptions" aria-label="Organizzazione"></select></label>
            <label>Evento <select asp-for="SelectedEventId" asp-items="Model.EventOptions" aria-label="Evento"></select></label>
            <label>Data <select asp-for="SelectedDateId" asp-items="Model.DateOptions" aria-label="Data"></select></label>
            <label>Turno <select asp-for="SelectedShiftId" asp-items="Model.ShiftOptions" aria-label="Turno"></select></label>
        </form>
    </section>
    <section class="menu-user" aria-label="Sessione">
        <p class="nav-section">Sessione</p>
        <div class="menu-user-row">
            <span class="role-chip">@Model.CurrentUser.Role</span>
            <a class="ghost-action" asp-page="/Logout">Esci</a>
        </div>
    </section>
</aside>

@page
@model IndexModel
@{
    ViewData["Title"] = "Panoramica";
}

<div class="app-shell">
    <partial name="_AppNav" model="Model" />
    <main class="main-stack">
        <partial name="_ContextHeader" model="Model" />

        <section class="stats-grid">
            <article class="stat-card">
                <span>Prenotazioni</span>
                <div class="stat-values">
                    <div><strong>@Model.ActiveReservations.Count</strong><small>prenotazioni</small></div>
                    <div><strong>@Model.BookedSeats</strong><small>persone</small></div>
                </div>
            </article>
            <article class="stat-card">
                <span>Tavoli</span>
                <div class="stat-values">
                    <div><strong>@Model.Tables.Count</strong><small>totali</small></div>
                    <div><strong>@Model.EstimatedFreeTables</strong><small>liberi stimati</small></div>
                </div>
            </article>
            <article class="stat-card">
                <span>Posti</span>
                <div class="stat-values">
                    <div><strong>@Model.TotalSeats</strong><small>totali</small></div>
                    <div><strong>@Model.FreeSeats</strong><small>liberi</small></div>
                </div>
            </article>
        </section>

        <section class="work-grid">
            <a class="panel nav-panel action-card action-bookings" asp-page="/Bookings"
               asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId"
               asp-route-SelectedEventId="@Model.SelectedEventId"
               asp-route-SelectedDateId="@Model.SelectedDateId"
               asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 3h10v4H7zM5 7h14v14H5zM8 12h8M8 16h6" /></svg></span>
                <span class="action-copy"><strong>Prenotazioni</strong><small>Inserimento, modifica, cancellazione e assegnazione manuale.</small></span>
            </a>
            <a class="panel nav-panel action-card action-reception" asp-page="/Reception"
               asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId"
               asp-route-SelectedEventId="@Model.SelectedEventId"
               asp-route-SelectedDateId="@Model.SelectedDateId"
               asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M8 21v-2a4 4 0 0 1 8 0v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM4 16h4M16 16h4" /></svg></span>
                <span class="action-copy"><strong>Accoglienza</strong><small>Ricerca rapida, presenti, annullate e non presentati.</small></span>
            </a>
            <a class="panel nav-panel action-card action-assignments" asp-page="/Assignments"
               asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId"
               asp-route-SelectedEventId="@Model.SelectedEventId"
               asp-route-SelectedDateId="@Model.SelectedDateId"
               asp-route-SelectedShiftId="@Model.SelectedShiftId">
                <span class="action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 10h16M6 10v9M18 10v9M8 6h8a3 3 0 0 1 3 3v1H5V9a3 3 0 0 1 3-3z" /></svg></span>
                <span class="action-copy"><strong>Assegnazione</strong><small>@Model.AssignmentSummary</small></span>
            </a>
            @if (Model.CanManageSetup)
            {
                <a class="panel nav-panel action-card action-config" asp-page="/Config"
                   asp-route-SelectedOrganizationId="@Model.SelectedOrganizationId"
                   asp-route-SelectedEventId="@Model.SelectedEventId"
                   asp-route-SelectedDateId="@Model.SelectedDateId"
                   asp-route-SelectedShiftId="@Model.SelectedShiftId">
                    <span class="action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM4 12h2m12 0h2M12 4v2m0 12v2M6.3 6.3l1.4 1.4m8.6 8.6 1.4 1.4m0-11.4-1.4 1.4m-8.6 8.6-1.4 1.4" /></svg></span>
                    <span class="action-copy"><strong>Configurazione</strong><small>Organizzazioni, utenti, eventi, date, turni, tavoli e audit.</small></span>
                </a>
            }
        </section>
    </main>
</div>

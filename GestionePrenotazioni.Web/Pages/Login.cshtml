@page
@model GestionePrenotazioni.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Accesso";
}

<main class="login-shell">
    <section class="login-panel">
        <p class="eyebrow">Gestione Prenotazioni</p>
        <h1>Accedi</h1>
        <form method="post" class="form-stack">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label>
                Utente
                <input asp-for="Input.UserName" autocomplete="username" autofocus />
            </label>
            <label>
                Password
                <input asp-for="Input.Password" type="password" autocomplete="current-password" />
            </label>
            <button type="submit" class="primary-action">Entra</button>
        </form>
    </section>
</main>
